GT_ENV=dev
GT_VERSION=0.1.0

GT_PG_DSN=postgresql+asyncpg://geotrace:geotrace@postgres:5432/geotrace
GT_REDIS_URL=redis://redis:6379/0
GT_CHROMA_URL=http://chroma:8000

# Set one of the following to enable live LLMs. Leave blank for offline stub.
GT_ANTHROPIC_API_KEY=
GT_OPENAI_API_KEY=

GT_PRIMARY_MODEL=claude-sonnet-4-6
GT_FALLBACK_MODEL=gpt-4.1-mini

GT_OTEL_ENDPOINT=http://otel-collector:4318
GT_LANGFUSE_PUBLIC_KEY=
GT_LANGFUSE_SECRET_KEY=

GT_DEFAULT_MAX_TOKENS=12000
GT_DEFAULT_MAX_TOOLS=8
GT_DEFAULT_MAX_SECONDS=30

GT_VESSEL_V_MAX_KTS=25
GT_VEHICLE_V_MAX_KMH=130

GT_HITL_CONFIDENCE_THRESHOLD=0.7
GT_SEMANTIC_CACHE_TTL_S=3600
GT_SEMANTIC_CACHE_SIMILARITY=0.92
